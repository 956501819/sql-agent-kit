# ========== LLM 配置 ==========
# 选择其中一个填写

# OpenAI / 兼容接口
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1   # 换成你的兼容接口地址
OPENAI_MODEL=gpt-4o

# 通义千问（阿里云 DashScope）
DASHSCOPE_API_KEY=sk-xxx
QWEN_MODEL=qwen-plus

# 阿里云百炼平台（https://bailian.console.aliyun.com/）
BAILIAN_API_KEY=sk-xxx
BAILIAN_MODEL=qwen-plus                     # 可选: qwen-max, qwen-turbo, qwen-long

# ========== 数据库配置 ==========
# 支持 MySQL / PostgreSQL / SQLite
DB_TYPE=mysql                               # mysql | postgresql | sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=your_database
# SQLite 只需填这一项
# DB_SQLITE_PATH=./data/local.db

# ========== Agent 配置 ==========
MAX_RETRY=3                                 # SQL 执行失败最大重试次数
CONFIDENCE_THRESHOLD=0.6                    # 低于此值时提示用户确认
LOG_PATH=./logs/queries.jsonl               # 查询日志路径
